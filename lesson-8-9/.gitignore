# Local .terraform directories (downloaded providers, etc.)
**/.terraform/*

# Terraform state files (may contain secrets — never commit)
*.tfstate
*.tfstate.*

# Temp backup made during the first-run bootstrap (mv backend.tf backend.tf.bak)
backend.tf.bak

# Crash log files
crash.log
crash.*.log

# Variable files that may contain sensitive data
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Saved plan output
*.tfplan

# CLI config files
.terraformrc
terraform.rc

# NOTE: .terraform.lock.hcl is intentionally NOT ignored — commit it so everyone
# uses the same provider versions.
