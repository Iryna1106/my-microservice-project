# Copy this file to ".env" and adjust the values for your machine.
# (".env" is ignored by git, so real passwords never reach GitHub.)

# --- PostgreSQL database ---
POSTGRES_DB=myproject
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Django ---
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=please-change-this-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1],web,django
